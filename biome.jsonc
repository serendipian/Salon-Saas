{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.worktrees",
      "!**/.playwright-mcp",
      "!**/.superpowers",
      "!**/.claude",
      "!**/.vscode",
      "!**/lib/database.types.ts",
      "!**/supabase/migrations",
      "!**/supabase/functions/**/*.ts",
      "!**/package-lock.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        // Audit-critical — keep as error:
        "noAlert": "error",
        "noExplicitAny": "error",
        "noConsole": { "level": "warn", "options": { "allow": ["error", "warn"] } },
        // Recommended but too noisy for this codebase; demote to warn:
        "noArrayIndexKey": "warn",
        "useIterableCallbackReturn": "warn",
        "noGlobalIsNan": "warn",
        "noImplicitAnyLet": "warn",
        "noShadowRestrictedNames": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "warn",
        "useParseIntRadix": "warn"
      },
      "style": {
        // Recommended but too noisy without effort-heavy refactor; demote to warn:
        "noNonNullAssertion": "warn",
        "useTemplate": "warn"
      },
      "complexity": {
        "useOptionalChain": "warn",
        "useLiteralKeys": "warn"
      },
      "a11y": {
        // Known audit items but not Safety Net scope; warn for now:
        "useButtonType": "warn",
        "noLabelWithoutControl": "warn"
      },
      "nursery": {
        "noFloatingPromises": "error"
      }
    }
  }
}
